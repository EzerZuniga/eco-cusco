# ============================================
# Variables de entorno para Eco Cusco API
# Copia este archivo como .env y llena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================

# PostgreSQL
POSTGRES_URL=jdbc:postgresql://localhost:5432/eco_cusco
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=

# JWT Secret (mínimo 256 bits / 32 caracteres)
APP_JWT_SECRET=
APP_JWT_EXP_MS=86400000

# Producción
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_DRIVER=org.postgresql.Driver
